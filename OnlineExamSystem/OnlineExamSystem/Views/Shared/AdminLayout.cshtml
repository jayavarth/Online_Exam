<!DOCTYPE html>
<html>
<head>
    <title>@ViewBag.Title</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #f5f7f2;
        }

        .container {
            display: flex;
        }

        .sidebar {
            width: 240px;
            height: 100vh;
            background: linear-gradient(180deg, #556B2F, #6B8E23);
            color: white;
            padding: 20px;
        }

        .menu a {
            display: block;
            color: #e8f0dc;
            padding: 10px;
            text-decoration: none;
            margin-bottom: 10px;
        }

            .menu a:hover {
                background: rgba(255,255,255,0.2);
            }

        .main {
            flex: 1;
            padding: 30px;
        }
    </style>
</head>

<body>

    <div class="container">

        <div class="sidebar">
            <h2>Admin Panel</h2>

            <div class="menu">
                @Html.ActionLink("Add Question", "AddQuestion", "Admin")
                @Html.ActionLink("View Questions", "ViewQuestions", "Admin")
                @Html.ActionLink("View Users", "ViewUsers", "Admin")
                @Html.ActionLink("View Results", "ViewResults", "Admin")
                @Html.ActionLink("Upload Excel", "UploadQuestions", "Admin")
            </div>
        </div>

        <div class="main">
            @RenderBody()
        </div>

    </div>

</body>
</html>
`
@{
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<h2>Welcome Admin 👋</h2>
<style>
    .main {
        flex: 1;
        padding: 40px 60px;
    }

    h2 {
        color: #2f3e1f;
        font-size: 26px;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 25px;
        margin-top: 30px;
    }

    .card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 14px 30px rgba(0,0,0,0.12);
        }

        .card h3 {
            margin-top: 0;
            color: #556B2F;
        }

        .card p {
            color: #666;
            font-size: 14px;
        }
    .btn {
        display: inline-block;
        margin-top: 15px;
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        color: white;
        background: #556B2F;
        font-size: 14px;
        transition: 0.3s;
    }

        .btn:hover {
            background: #3e4f22;
        }
</style>

<div class="cards">

    <div class="card">
        <h3> Add Question</h3>
        <p>Create and manage exam questions.</p>
        @Html.ActionLink("Go", "AddQuestion", "Admin", null, new { @class = "btn" })
    </div>

    <div class="card">
        <h3> View Questions</h3>
        <p>Edit or delete existing questions.</p>
        @Html.ActionLink("Go", "ViewQuestions", "Admin", null, new { @class = "btn" })
    </div>

    <div class="card">
        <h3> View Results</h3>
        <p>Analyze exam performance.</p>
        @Html.ActionLink("Go", "ViewResults", "Admin", null, new { @class = "btn" })
    </div>

</div>

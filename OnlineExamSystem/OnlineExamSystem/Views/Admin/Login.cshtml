@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Login</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
        }

        .container {
            display: flex;
            width: 100%;
        }

        .left {
            flex: 1;
            background: linear-gradient(135deg, #556B2F, #6B8E23);
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 40px;
            text-align: center;
        }

            .left img {
                width: 70%;
                max-width: 300px;
            }

            .left h1 {
                margin-top: 20px;
            }

        .right {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f5f7f2;
        }

        .login-card {
            background: white;
            padding: 40px;
            width: 350px;
            border-radius: 14px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
            color: #556B2F;
        }

        label {
            font-size: 14px;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-top: 6px;
            margin-bottom: 12px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

            input:focus {
                outline: none;
                border-color: #556B2F;
            }

        .btn {
            width: 100%;
            padding: 12px;
            background: #556B2F;
            border: none;
            color: white;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn:hover {
                e4f22;
            }

        .captcha {
            font-size: 13px;
            margin-bottom: 5px;
            color: #2f3e1f;
            font-weight: 500;
        }

        .footer {
            text-align: center;
            margin-top: 15px;
            font-size: 13px;
            line-height: 1.8;
        }

            .footer a {
                color: #556B2F;
                text-decoration: none;
                font-weight: 500;
            }

                .footer a:hover {
                    color: #3e4f22;
                    text-decoration: underline;
                }

        .error {
            text-align: center;
            margin-top: 10px;
            color: red;
        }
    </style>
</head>

<body>

    <div class="container">

        <div class="left">
            <div>
                <img src="https://cdn-icons-png.flaticon.com/512/3064/3064155.png" />
                <h1>Admin Panel</h1>
                <p>Manage exams, users and results</p>
            </div>
        </div>

        <div class="right">
            <div class="login-card">

                <h2>Admin Login</h2>

                @using (Html.BeginForm())
                {
                    <label>Email</label>
                    <input type="text" name="email" placeholder="Enter admin email" required />

                    <label>Password</label>
                    <input type="password" name="password" placeholder="Enter password" required />

                    <div class="captcha">Captcha : @ViewBag.Captcha</div>
                    <input type="text" name="captchaInput" placeholder="Enter Captcha" required />

                    <button type="submit" class="btn">Login</button>
                }

                <div class="footer">
                    @Html.ActionLink("Forgot Password?", "ForgotPassword", "Admin")
                    <br />
                    @Html.ActionLink("Back to User Login", "Login", "Account")
                </div>

                @if (ViewBag.Message != null)
                {
                    <div class="error">
                        @ViewBag.Message
                    </div>
                }

            </div>
        </div>

    </div>

</body>
</html>
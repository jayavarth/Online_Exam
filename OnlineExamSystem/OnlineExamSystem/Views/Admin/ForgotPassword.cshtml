@{
    ViewBag.Title = "ForgotPassword";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Forgot Password</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
        }

        .container {
            display: flex;
            width: 100%;
        }

        .left {
            flex: 1;
            background: linear-gradient(135deg, #556B2F, #6B8E23);
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            padding: 40px;
        }

            .left img {
                width: 70%;
                max-width: 250px;
            }

        .right {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f5f7f2;
        }

        .card {
            background: white;
            padding: 40px;
            width: 360px;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
            color: #556B2F;
            margin-bottom: 20px;
        }

        label {
            font-size: 13px;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-top: 6px;
            margin-bottom: 15px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

            input:focus {
                outline: none;
                border-color: #556B2F;
            }

        .btn {
            width: 100%;
            padding: 12px;
            background: #556B2F;
            border: none;
            color: white;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn:hover {
                background: #3e4f22;
            }

        .message {
            text-align: center;
            color: green;
            margin-top: 10px;
        }

        .footer {
            text-align: center;
            margin-top: 15px;
            font-size: 13px;
        }

            .footer a {
                color: #556B2F;
                text-decoration: none;
            }

                .footer a:hover {
                    text-decoration: underline;
                }
    </style>
</head>

<body>

    <div class="container">

        <div class="left">
            <div>
                <img src="https://cdn-icons-png.flaticon.com/512/3064/3064155.png" />
                <h1>Admin Reset</h1>
                <p>Secure your account</p>
            </div>
        </div>

        <div class="right">
            <div class="card">

                <h2>Forgot Password</h2>

                @using (Html.BeginForm())
                {
                    <label>Email</label>
                    <input type="email" name="email" required />

                    <label>New Password</label>
                    <input type="password" name="newPassword" required />

                    <button type="submit" class="btn">Reset Password</button>
                }

                @if (ViewBag.Message != null)
                {
                    <div class="message">
                        @ViewBag.Message
                    </div>
                }

                <div class="footer">
                    @Html.ActionLink("← Back to Admin Login", "Login", "Admin")
                </div>

            </div>
        </div>

    </div>

</body>
</html>
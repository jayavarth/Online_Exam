@model IEnumerable<OnlineExamSystem.Models.Question>

@{
    Layout = null;
}

<style>
    body {
        background: #121212;
        font-family: 'Segoe UI', sans-serif;
        color: white;
    }

    .page-container {
        padding: 25px;
    }

    .title {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .card {
        background: #1e1e1e;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #5b2be0;
        padding: 12px;
        text-align: left;
        font-size: 14px;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #333;
    }

    tr:hover {
        background: #2a2a2a;
    }

    /* Delete Button */
    .delete-btn {
        background: #ff4d4d;
        color: white;
        padding: 6px 12px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
    }

        .delete-btn:hover {
            background: #e60000;
        }

    /* ID Badge */
    .id-badge {
        background: #333;
        padding: 4px 8px;
        border-radius: 5px;
        font-size: 12px;
    }
</style>

<div class="page-container">

    <div class="title">📄 Questions List</div>

    <div class="card">

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Question</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var q in Model)
                {
                    <tr>
                        <td>
                            <span class="id-badge">@q.QuestionId</span>
                        </td>

                        <td>@q.QuestionText</td>

                        <td>
                            <a href="/Admin/DeleteQuestion/@q.QuestionId"
                               class="delete-btn"
                               onclick="return confirm('Are you sure you want to delete this question?');">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>
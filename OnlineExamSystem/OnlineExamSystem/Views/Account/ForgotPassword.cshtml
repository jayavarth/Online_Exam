
@{
    ViewBag.Title = "ForgotPassword";
}

<h2>Forgot Password</h2>

@using (Html.BeginForm())
{
    <label>Email</label>
    <input type="email" name="email" required />

    <br />
    <br />

    <label>New Password</label>
    <input type="password" name="newPassword" required />

    <br />
    <br />

    <button type="submit">
        Reset Password
    </button>
}

<h3 style="color:green">
    @ViewBag.Message
</h3>


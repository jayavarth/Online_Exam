@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #f5f7f2;
        }

        .container {
            display: flex;
        }


        .sidebar {
            width: 240px;
            height: 100vh;
            background: linear-gradient(180deg, #556B2F, #6B8E23);
            color: white;
            padding: 25px;
        }

            .sidebar h2 {
                margin-bottom: 35px;
                font-weight: 600;
            }

        .menu a {
            display: block;
            color: #e8f0dc;
            text-decoration: none;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 10px;
            transition: 0.3s;
        }

            .menu a:hover {
                background: rgba(255,255,255,0.15);
                padding-left: 15px;
            }

        .main {
            flex: 1;
            padding: 30px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .welcome {
            font-size: 24px;
            font-weight: 600;
            color: #2f3e1f;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 30px;
        }

        .card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.08);
            transition: 0.3s;
        }

            .card:hover {
                transform: translateY(-5px);
            }

            .card h3 {
                color: #556B2F;
            }

            .card p {
                color: #666;
            }

        .btn {
            display: inline-block;
            margin-top: 10px;
            color: white;
            border-radius: 6px;
            text-decoration: none;
            transition: 0.3s;
        }

            .btn:hover {
                background: #3e4f22;
            }
    </style>
</head>

<body>

        <div class="container">

            <div class="sidebar">
                <h2>Exam Portal</h2>

                <div class="menu">
                    <a href="#">Dashboard</a>

                    <a href="/Exam/SelectExam">Start Exam</a>

                    <a href="/Exam/MyResults">My Results</a>

            </div>
            </div>

            <div class="main">

                <div class="header">
                    <div class="welcome">
                        Welcome, @Session["UserName"]
                    </div>
                </div>

                <div class="cards">

                    <div class="card">
                        <h3>Start Exam</h3>
                        <p>Begin a new exam and test your knowledge.</p>
                        <a href="/Exam/SelectExam" class="btn">Start</a>
                    </div>

                    <div class="card">
                        <h3>My Results</h3>
                        <p>View your past performance and scores.</p>
                        <a href="/Exam/MyResults" class="btn">View Results</a>
                    </div>

                    <div class="card">
                        <h3>Progress</h3>
                        <p>Track your exam improvement.</p>
                        <a href="#" class="btn">View</a>
                    </div>
                </div>
            </div>
        </div>

    </body>
</html>

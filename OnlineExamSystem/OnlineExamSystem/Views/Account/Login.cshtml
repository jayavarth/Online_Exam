<!DOCTYPE html>
<html>
<head>
    <title>Login</title>

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
        }

        .container {
            display: flex;
            width: 100%;
        }

        /* LEFT SIDE (Illustration) */
        .left {
            flex: 1;
            background: linear-gradient(135deg, #5b2be0, #7e4cff);

            justify-content: center;
            align-items: center;
            color: white;
            padding: 40px;
        }

        .left img {
            width: 80%;
            max-width: 400px;
        }

        .left h1 {
            margin-top: 20px;
        }

        /* RIGHT SIDE (Login) */
        .right {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f5f6fa;
        }

        .login-card {
            background: white;
            padding: 40px;
            width: 350px;
            border-radius: 14px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .login-card h2 {
            text-align: center;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            font-size: 14px;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-top: 6px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

        input:focus {
            outline: none;
            border-color: #5b2be0;
        }

        .btn {
            width: 100%;
            padding: 12px;
            background: #5b2be0;
            border: none;
            color: white;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
        }

        .btn:hover {
            background: #4520c5;
        }

        .error {
            text-align: center;
            margin-top: 15px;
            color: red;
        }

        
    </style>
</head>

<body>

    <div class="container">

        <!-- Illustration Section -->
        <div class="left">
            <div>
                <!-- Replace with your own image -->
                <img src="https://cdn-icons-png.flaticon.com/512/3209/3209265.png" />

                <h1>Online Exam Portal</h1>
                <p>Practice, Learn, and Improve your skills</p>
            </div>
        </div>

        <!-- Login Section -->
        <div class="right">
            <div class="login-card">

                <h2>Welcome Back</h2>

                @using (Html.BeginForm())
                {
                    <div class="form-group">
                        <label>Email</label>
                        <input type="text" name="email" required />
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="password" required />
                    </div>

                    <button type="submit" class="btn">Login</button>
                }

                <div class="error">
                    @ViewBag.Message
                </div>

            </div>
        </div>

    </div>

</body>
</html>

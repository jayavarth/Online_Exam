@model OnlineExamSystem.Models.User

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Register</title>

    <script src="@Url.Content("~/Scripts/jquery-3.7.0.min.js")"></script>
    <script src="@Url.Content("~/Scripts/jquery.validate.min.js")"></script>
    <script src="@Url.Content("~/Scripts/jquery.validate.unobtrusive.min.js")"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
        }

        .container {
            display: flex;
            width: 100%;
        }

        .left {
            flex: 1;
            background: linear-gradient(135deg, #556B2F, #6B8E23);
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            padding: 40px;
        }

            .left img {
                width: 70%;
                max-width: 300px;
            }
        .right {
            flex: 1;
            background: #f5f7f2;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 40px 0;
            overflow-y: auto;
        }

        .form-card {
            background: white;
            width: 420px;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
            color: #556B2F;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 12px;
        }

        label {
            font-size: 13px;
            font-weight: 500;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

            input:focus, select:focus {
                outline: none;
                border-color: #556B2F;
            }

        .btn {
            width: 100%;
            padding: 12px;
            background: #556B2F;
            border: none;
            color: white;
            border-radius: 8px;
            margin-top: 10px;
            transition: 0.3s;
        }

            .btn:hover {
                background: #3e4f22;
            }

        .error {
            color: red;
            font-size: 12px;
        }

        .footer {
            text-align: center;
            margin-top: 15px;
            font-size: 13px;
        }

            .footer a {
                color: #556B2F;
                font-weight: 500;
                text-decoration: none;
            }

                .footer a:hover {
                    text-decoration: underline;
                }
    </style>
</head>

<body>
    <script>
        $(document).ready(function () {

            $("#CountryId").change(function () {

                var countryId = $(this).val();

                $("#StateId").empty();
                $("#CityId").empty();

                $.getJSON('/Account/GetStates', { countryId: countryId }, function (data) {

                    $("#StateId").append('<option value="">Select State</option>');

                    $.each(data, function (i, item) {
                        $("#StateId").append(
                            '<option value="' + item.StateId + '">' + item.StateName + '</option>'
                        );
                    });
                });
            });

            $("#StateId").change(function () {

                var stateId = $(this).val();
                $("#CityId").empty();

                $.getJSON('/Account/GetCities', { stateId: stateId }, function (data) {

                    $("#CityId").append('<option value="">Select City</option>');

                    $.each(data, function (i, item) {
                        $("#CityId").append(
                            '<option value="' + item.CityId + '">' + item.CityName + '</option>'
                        );
                    });
                });
            });

        });
    </script>

    <div class="container">

        <div class="left">
            <div>
                <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" />
                <h1>Create Account</h1>
                <p>Start your journey with us</p>
            </div>
        </div>

        <div class="right">
            <div class="form-card">

                <h2>Register</h2>

                @Html.ValidationSummary(true, "", new { @class = "error" })

                @using (Html.BeginForm())
                {
                    <div class="form-group">
                        <label>Full Name</label>
                        @Html.TextBoxFor(m => m.FullName)
                        @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        @Html.TextBoxFor(m => m.Email)
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        @Html.PasswordFor(m => m.Password)
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Confirm Password</label>
                        @Html.PasswordFor(m => m.ConfirmPassword)
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Mobile</label>
                        @Html.TextBoxFor(m => m.Mobile)
                        @Html.ValidationMessageFor(m => m.Mobile, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Country</label>
                        @Html.DropDownListFor(m => m.CountryId,
                            (ViewBag.Countries as SelectList),
                            "--Select Country--",
                            new { id = "CountryId" })
                    </div>

                    <div class="form-group">
                        <label>State</label>
                        <select id="StateId" name="StateId">
                            <option>Select State</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>City</label>
                        <select id="CityId" name="CityId">
                            <option>Select City</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>DOB</label>
                        @Html.TextBoxFor(m => m.DOB, "{0:yyyy-MM-dd}", new { type = "date" })
                        @Html.ValidationMessageFor(m => m.DOB, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Qualification</label>
                        @Html.DropDownListFor(m => m.QualificationId,
                            (ViewBag.Qualifications as SelectList),
                            "--Select Qualification--")
                    </div>

                    <div class="form-group">
                        <label>Year Of Completion</label>
                        @Html.TextBoxFor(m => m.YearOfCompletion)
                        @Html.ValidationMessageFor(m => m.YearOfCompletion, "", new { @class = "error" })
                    </div>

                    <button type="submit" class="btn">Register</button>
                }

                <div class="error">
                    @ViewBag.Message
                </div>

                <div class="footer">
                    Already have an account?
                    @Html.ActionLink("Login", "Login", "Account")
                </div>

            </div>
        </div>

    </div>

</body>
</html>
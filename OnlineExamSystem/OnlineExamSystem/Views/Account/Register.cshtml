@model OnlineExamSystem.Models.User

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Register</title>

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
        }

        .container {
            display: flex;
            width: 100%;
        }

        /* LEFT (Illustration) */
        .left {
            flex: 1;
            background: linear-gradient(135deg, #5b2be0, #7e4cff);
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 40px;
        }

            .left img {
                width: 80%;
                max-width: 400px;
            }

        /* RIGHT (Form) */
        .right {
            flex: 1;
            overflow-y: auto;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            background: #f5f6fa;
            padding: 40px 0;
        }

        .form-card {
            background: white;
            width: 400px;
            padding: 30px;
            border-radius: 14px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

            .form-card h2 {
                text-align: center;
                margin-bottom: 20px;
            }

        .form-group {
            margin-bottom: 12px;
        }

        label {
            font-size: 13px;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 9px;
            margin-top: 5px;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 13px;
        }

            input:focus {
                outline: none;
                border-color: #5b2be0;
            }

        .btn {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            background: #5b2be0;
            border: none;
            color: white;
            border-radius: 8px;
            font-size: 15px;
            cursor: pointer;
        }

            .btn:hover {
                background: #4520c5;
            }

        .error {
            color: red;
            font-size: 12px;
        }

        .footer {
            text-align: center;
            margin-top: 15px;
            font-size: 13px;
        }
    </style>
</head>

<body>

    <div class="container">

        <!-- LEFT -->
        <div class="left">
            <div>
                <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" />
                <h1>Create Account</h1>
                <p>Join and start your exam journey</p>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="right">
            <div class="form-card">

                <h2>Register</h2>

                <!-- ✅ Validation Summary -->
                @Html.ValidationSummary(true, "", new { @class = "error" })

                @using (Html.BeginForm())
                {
                    <div class="form-group">
                        <label>Full Name</label>
                        @Html.TextBoxFor(m => m.FullName)
                        @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        @Html.TextBoxFor(m => m.Email)
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        @Html.PasswordFor(m => m.Password)
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "error" })
                    </div>

                    <!-- ✅ Added Confirm Password -->
                    <div class="form-group">
                        <label>Confirm Password</label>
                        @Html.PasswordFor(m => m.ConfirmPassword)
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Mobile</label>
                        @Html.TextBoxFor(m => m.Mobile)
                        @Html.ValidationMessageFor(m => m.Mobile, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>City</label>
                        @Html.TextBoxFor(m => m.City)
                        @Html.ValidationMessageFor(m => m.City, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>State</label>
                        @Html.TextBoxFor(m => m.State)
                        @Html.ValidationMessageFor(m => m.State, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>DOB</label>
                        @Html.TextBoxFor(m => m.DOB, "{0:yyyy-MM-dd}", new { type = "date" })
                        @Html.ValidationMessageFor(m => m.DOB, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Qualification</label>
                        @Html.TextBoxFor(m => m.Qualification)
                        @Html.ValidationMessageFor(m => m.Qualification, "", new { @class = "error" })
                    </div>

                    <div class="form-group">
                        <label>Year Of Completion</label>
                        @Html.TextBoxFor(m => m.YearOfCompletion)
                        @Html.ValidationMessageFor(m => m.YearOfCompletion, "", new { @class = "error" })
                    </div>

                    <button type="submit" class="btn">Register</button>
                }

                <!-- ✅ Server message -->
                <div class="error">
                    @ViewBag.Message
                </div>

                <!-- ✅ FIXED LINK -->
                <div class="footer">
                    Already have an account?
                    <a href="/Account/Login">Login</a>
                </div>

            </div>
        </div>

    </div>

    @section Scripts
{
        @Scripts.Render("~/bundles/jqueryval")
    }

</body>
</html>

@{
    ViewBag.Title = "MyResults";
}

@model IEnumerable<OnlineExamSystem.Models.Result>

<style>
    h2 {
        text-align: center;
        color: darkblue;
        margin-bottom: 20px;
    }

    table {
        width: 80%;
        margin: auto;
        border-collapse: collapse;
        font-family: Arial;
    }

    th {
        background-color: #4CAF50;
        color: white;
        padding: 10px;
    }

    td {
        text-align: center;
        padding: 8px;
    }

    tr:nth-child(even) {
        background-color: #f2f2f2;
    }

    tr:hover {
        background-color: #ddd;
    }
</style>

<h2>My Results</h2>

<table>
    <tr>
        <th>Exam</th>
        <th>Score</th>
        <th>Status</th>
        <th>Date</th>
    </tr>

    @foreach (var r in Model)
{
    <tr>
        <td>@r.ExamId</td>
        <td>@r.Score</td>
        <td>@r.Status</td>
        <td>@r.ExamDate</td>
    </tr>
}

</table>

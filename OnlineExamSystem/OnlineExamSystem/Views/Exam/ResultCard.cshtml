@{
    ViewBag.Title = "ResultCard";
}
@model OnlineExamSystem.Models.Result

<style>
    body {
        font-family: Arial;
        background-color: #f8f8f8;
    }

    .card {
        width: 350px;
        margin: 40px auto;
        padding: 20px;
        background: white;
        border-radius: 10px;
        box-shadow: 0px 0px 10px gray;
        text-align: center;
    }

    h2 {
        color: #556B2F;
    }

    .btn {
        padding: 10px 20px;
        background: linear-gradient(180deg, #556B2F, #6B8E23);
        color: white;
        text-decoration: none;
        border-radius: 5px;
    }

    .pass {
        color: green;
    }

    .fail {
        color: red;
    }
</style>

<div class="card">
    <h2>Result Card</h2>

    <p>Score: @Model.Score</p>
    <p>Status: @Model.Status</p>
    <p>Date: @Model.ExamDate</p>

    @if (Model.Status == "PASS")
    {
        <h3 class="pass">Congratulations</h3>
    }
    else
    {
        <h3 class="fail">Better Luck Next Time</h3>
    }

    <br />
    <a href="/Account/Dashboard" class="btn">Back To Dashboard</a>
</div>
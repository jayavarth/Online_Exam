@{
    ViewBag.Title = "ResultCard";
}

@model OnlineExamSystem.Models.Result

<style>
    .card {
        width: 400px;
        margin: auto;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0px 0px 10px gray;
        text-align: center;
        font-family: Arial;
    }

    h2 {
        color: darkblue;
    }

    .score, .status, .date {
        font-size: 18px;
        margin: 10px 0;
    }

    .pass {
        color: green;
        font-weight: bold;
    }

    .fail {
        color: red;
        font-weight: bold;
    }

    .btn {
        display: inline-block;
        margin-top: 15px;
        padding: 10px 20px;
        background-color: blue;
        color: white;
        text-decoration: none;
        border-radius: 5px;
    }

        .btn:hover {
            background-color: darkblue;
        }
</style>

<div class="card">

    <h2>Result Card</h2>

    <hr />

    <div class="score">
        Score: @Model.Score
    </div>

    <div class="status">
        Status: @Model.Status
    </div>

    <div class="date">
        Date: @Model.ExamDate
    </div>

    @if (Model.Status == "PASS")
    {
    <h3 class="pass">Congratulations</h3>
    }
    else
    {
    <h3 class="fail">Better Luck Next Time</h3>
    }

    <a href="/Account/Dashboard" class="btn">
        Back To Dashboard
    </a>

</div>
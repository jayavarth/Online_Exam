@{
    ViewBag.Title = "StartExam";
}
@model IEnumerable<OnlineExamSystem.Models.Question>

<style>
    body {
        font-family: Arial;
        background-color: #f8f8f8;
        color: black; /* IMPORTANT FIX */
    }

    /* Remove bad global styles */
    .question-box, .question-box * {
        background: white !important;
        color: black !important;
    }

    /* Heading */
    h2 {
        text-align: center;
        color: #556B2F;
    }

    /* Timer */
    #timer {
        text-align: right;
        font-size: 20px;
        color: #556B2F;
        margin-right: 20px;
        margin-bottom: 10px;
    }

    /* Question card */
    .question-box {
        width: 80%;
        margin: 20px auto;
        padding: 15px;
        border-radius: 8px;
        box-shadow: 0px 0px 8px gray;
    }

    /* Question text */
    .question-text {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    /* Options */
    .option {
        margin: 6px 0;
    }

    /* Button */
    .btn {
        display: block;
        margin: 25px auto;
        padding: 10px 20px;
        background: linear-gradient(180deg, #556B2F, #6B8E23);
        color: white;
        border: none;
        border-radius: 5px;
        font-size: 16px;
        cursor: pointer;
    }
</style>

<h2>Online Exam</h2>

<div id="timer">30:00</div>

<form method="post" action="/Exam/SubmitExam" id="examForm">

    @foreach (var q in Model)
    {
        <div class="question-box">

            <input type="hidden" name="QuestionId" value="@q.QuestionId" />

            <div class="question-text">
                @q.QuestionText
            </div>

            <div class="option">
                <input type="radio" name="Answer_@q.QuestionId" value="A" />
                @q.OptionA
            </div>

            <div class="option">
                <input type="radio" name="Answer_@q.QuestionId" value="B" />
                @q.OptionB
            </div>

            <div class="option">
                <input type="radio" name="Answer_@q.QuestionId" value="C" />
                @q.OptionC
            </div>

            <div class="option">
                <input type="radio" name="Answer_@q.QuestionId" value="D" />
                @q.OptionD
            </div>

        </div>
    }

    <button type="submit" class="btn">Submit Exam</button>

</form>

<script>
    var time = 1800; // 30 minutes

    var timer = setInterval(function () {

        time--;

        var minutes = Math.floor(time / 60);
        var seconds = time % 60;

        if (seconds < 10) {
            seconds = "0" + seconds;
        }

        document.getElementById("timer").innerHTML =
            minutes + ":" + seconds;

        if (time <= 0) {
            clearInterval(timer);
            document.getElementById("examForm").submit();
        }

    }, 1000);
</script>